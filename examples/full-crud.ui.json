{
  "protocol_version": "open-ui-ir.v1",
  "app_name": "work-items",
  "display_name": "Work Items",
  "default_locale": "en-US",
  "locales": [
    {
      "locale": "en-US",
      "label": "English"
    }
  ],
  "messages": {
    "en-US": {}
  },
  "capabilities": {
    "layouts": [
      "crud_list",
      "detail_page",
      "dashboard"
    ],
    "component_kinds": [
      "filter_bar",
      "table",
      "detail_header",
      "metric_row",
      "chart"
    ],
    "field_renderers": [
      {
        "kind": "text",
        "description": "Plain text"
      },
      {
        "kind": "badge",
        "description": "Compact categorical value"
      },
      {
        "kind": "datetime",
        "description": "Locale-aware timestamp"
      },
      {
        "kind": "number",
        "description": "Locale-aware number"
      },
      {
        "kind": "json",
        "description": "Structured JSON payload"
      }
    ],
    "filter_kinds": [
      "text",
      "select",
      "multi_select",
      "date_range",
      "boolean"
    ],
    "action_methods": [
      "get",
      "create",
      "update",
      "delete",
      "custom"
    ]
  },
  "collections": [
    {
      "name": "workItems",
      "resource_type": "WorkItem",
      "plural_field": "workItems",
      "list": {
        "transport": "graphql",
        "operation": "workItems",
        "variables": {
          "page_size": {
            "kind": "page",
            "path": "page_size"
          },
          "page_token": {
            "kind": "page",
            "path": "page_token"
          },
          "filter": {
            "kind": "filters"
          }
        },
        "result": {
          "path": "workItems.workItems"
        }
      },
      "get": {
        "transport": "graphql",
        "operation": "workItem",
        "variables": {
          "name": {
            "kind": "route",
            "path": "name"
          }
        },
        "result": {
          "path": "workItem"
        }
      },
      "fields": [
        {
          "name": "name",
          "value_type": "string",
          "renderer": "text",
          "required": true,
          "output_only": true
        },
        {
          "name": "title",
          "value_type": "string",
          "renderer": "text",
          "required": true,
          "output_only": false
        },
        {
          "name": "state",
          "value_type": "string",
          "renderer": "badge",
          "required": true,
          "output_only": false
        },
        {
          "name": "priority",
          "value_type": "string",
          "renderer": "badge",
          "required": false,
          "output_only": false
        },
        {
          "name": "owner",
          "value_type": "string",
          "renderer": "text",
          "required": false,
          "output_only": false
        },
        {
          "name": "blocked",
          "value_type": "boolean",
          "renderer": "badge",
          "required": false,
          "output_only": false
        },
        {
          "name": "estimate_points",
          "value_type": "number",
          "renderer": "number",
          "required": false,
          "output_only": false
        },
        {
          "name": "updated_at",
          "value_type": "datetime",
          "renderer": "datetime",
          "required": true,
          "output_only": true
        },
        {
          "name": "payload",
          "value_type": "json",
          "renderer": "json",
          "required": false,
          "output_only": true
        }
      ],
      "filters": [
        {
          "name": "q",
          "label": "Search",
          "kind": "text",
          "cel_field": "title"
        },
        {
          "name": "state",
          "label": "State",
          "kind": "select",
          "cel_field": "state",
          "options": [
            {
              "label": "Open",
              "value": "open"
            },
            {
              "label": "In Progress",
              "value": "in_progress"
            },
            {
              "label": "Done",
              "value": "done"
            }
          ]
        },
        {
          "name": "priority",
          "label": "Priority",
          "kind": "multi_select",
          "cel_field": "priority",
          "options": [
            {
              "label": "High",
              "value": "high"
            },
            {
              "label": "Medium",
              "value": "medium"
            },
            {
              "label": "Low",
              "value": "low"
            }
          ]
        },
        {
          "name": "updated",
          "label": "Updated",
          "kind": "date_range",
          "cel_field": "updated_at"
        },
        {
          "name": "blocked",
          "label": "Blocked",
          "kind": "boolean",
          "cel_field": "blocked"
        }
      ],
      "actions": [
        {
          "name": "open",
          "label": "Open",
          "method": "get",
          "binding": {
            "transport": "graphql",
            "operation": "workItem",
            "variables": {
              "name": {
                "kind": "resource",
                "path": "name"
              }
            },
            "result": {
              "path": "workItem"
            }
          }
        },
        {
          "name": "create",
          "label": "Create",
          "method": "create",
          "binding": {
            "transport": "graphql",
            "operation": "createWorkItem",
            "variables": {
              "body": {
                "kind": "form"
              }
            },
            "result": {
              "path": "createWorkItem"
            }
          },
          "form": {
            "fields": [
              {
                "field": "title",
                "label": "Title",
                "control": "text",
                "required": true
              },
              {
                "field": "state",
                "label": "State",
                "control": "select",
                "required": true,
                "options": [
                  {
                    "label": "Open",
                    "value": "open"
                  },
                  {
                    "label": "In Progress",
                    "value": "in_progress"
                  },
                  {
                    "label": "Done",
                    "value": "done"
                  }
                ]
              },
              {
                "field": "priority",
                "label": "Priority",
                "control": "select",
                "options": [
                  {
                    "label": "High",
                    "value": "high"
                  },
                  {
                    "label": "Medium",
                    "value": "medium"
                  },
                  {
                    "label": "Low",
                    "value": "low"
                  }
                ]
              },
              {
                "field": "owner",
                "label": "Owner",
                "control": "text"
              },
              {
                "field": "blocked",
                "label": "Blocked",
                "control": "checkbox"
              },
              {
                "field": "estimate_points",
                "label": "Estimate",
                "control": "number"
              }
            ]
          },
          "interaction": {
            "submit": {
              "presentation": "modal",
              "pending_message": "Creating work item",
              "disable_while_pending": true
            },
            "outcome": {
              "success_message": "Created work item",
              "failure_message": "Could not create work item"
            },
            "optimistic_update": {
              "mode": "prepend_resource"
            }
          }
        },
        {
          "name": "update",
          "label": "Update",
          "method": "update",
          "binding": {
            "transport": "graphql",
            "operation": "updateWorkItem",
            "variables": {
              "name": {
                "kind": "resource",
                "path": "name"
              },
              "body": {
                "kind": "form"
              },
              "update_mask": {
                "kind": "form",
                "path": "update_mask"
              }
            },
            "result": {
              "path": "updateWorkItem"
            }
          },
          "form": {
            "fields": [
              {
                "field": "title",
                "label": "Title",
                "control": "text",
                "required": true
              },
              {
                "field": "state",
                "label": "State",
                "control": "select",
                "required": true,
                "options": [
                  {
                    "label": "Open",
                    "value": "open"
                  },
                  {
                    "label": "In Progress",
                    "value": "in_progress"
                  },
                  {
                    "label": "Done",
                    "value": "done"
                  }
                ]
              },
              {
                "field": "priority",
                "label": "Priority",
                "control": "select",
                "options": [
                  {
                    "label": "High",
                    "value": "high"
                  },
                  {
                    "label": "Medium",
                    "value": "medium"
                  },
                  {
                    "label": "Low",
                    "value": "low"
                  }
                ]
              },
              {
                "field": "owner",
                "label": "Owner",
                "control": "text"
              },
              {
                "field": "blocked",
                "label": "Blocked",
                "control": "checkbox"
              },
              {
                "field": "estimate_points",
                "label": "Estimate",
                "control": "number"
              }
            ],
            "update_mask": {
              "variable": "update_mask",
              "value": {
                "kind": "form",
                "path": "update_mask"
              }
            }
          },
          "interaction": {
            "submit": {
              "presentation": "modal",
              "pending_message": "Updating work item",
              "disable_while_pending": true
            },
            "outcome": {
              "success_message": "Updated work item",
              "failure_message": "Could not update work item"
            },
            "optimistic_update": {
              "mode": "patch_resource"
            }
          }
        },
        {
          "name": "close",
          "label": "Close",
          "method": "custom",
          "binding": {
            "transport": "graphql",
            "operation": "closeWorkItem",
            "variables": {
              "name": {
                "kind": "resource",
                "path": "name"
              }
            },
            "result": {
              "path": "closeWorkItem"
            }
          },
          "interaction": {
            "outcome": {
              "success_message": "Closed work item",
              "failure_message": "Could not close work item"
            },
            "optimistic_update": {
              "mode": "patch_resource"
            }
          }
        },
        {
          "name": "delete",
          "label": "Delete",
          "method": "delete",
          "binding": {
            "transport": "graphql",
            "operation": "deleteWorkItem",
            "variables": {
              "name": {
                "kind": "resource",
                "path": "name"
              }
            },
            "result": {
              "path": "deleteWorkItem"
            }
          },
          "interaction": {
            "confirmation": {
              "title": "Delete work item?",
              "message": "This removes the selected work item.",
              "confirm_label": "Delete",
              "cancel_label": "Cancel",
              "destructive": true
            },
            "outcome": {
              "success_message": "Deleted work item",
              "failure_message": "Could not delete work item"
            },
            "optimistic_update": {
              "mode": "remove_resource"
            }
          }
        }
      ],
      "pagination": {
        "kind": "keyset",
        "page_size_param": "page_size",
        "page_token_param": "page_token",
        "next_page_token_path": "workItems.nextPageToken",
        "order_by": [
          {
            "field": "updated_at",
            "direction": "desc"
          },
          {
            "field": "name",
            "direction": "asc"
          }
        ],
        "unique_key_fields": [
          "name"
        ]
      }
    }
  ],
  "routes": [
    {
      "route": "/work-items",
      "title": "Work Items",
      "layout": "crud_list",
      "navigation": {
        "group": "Work",
        "order": 1
      },
      "data_bindings": [
        {
          "name": "rows",
          "query": {
            "transport": "graphql",
            "operation": "workItems",
            "variables": {
              "page_size": {
                "kind": "page",
                "path": "page_size"
              },
              "page_token": {
                "kind": "page",
                "path": "page_token"
              },
              "filter": {
                "kind": "filters"
              }
            },
            "result": {
              "path": "workItems.workItems"
            }
          }
        }
      ],
      "components": [
        {
          "id": "filters",
          "kind": "filter_bar",
          "collection": "workItems"
        },
        {
          "id": "table",
          "kind": "table",
          "data": {
            "binding": "rows"
          },
          "table": {
            "collection": "workItems",
            "columns": [
              {
                "id": "title",
                "field": "title",
                "label": "Title",
                "sortable": false,
                "visible": true
              },
              {
                "id": "state",
                "field": "state",
                "label": "State",
                "sortable": false,
                "visible": true
              },
              {
                "id": "priority",
                "field": "priority",
                "label": "Priority",
                "sortable": false,
                "visible": true
              },
              {
                "id": "owner",
                "field": "owner",
                "label": "Owner",
                "sortable": false,
                "visible": true
              },
              {
                "id": "updated",
                "field": "updated_at",
                "label": "Updated",
                "sortable": true,
                "visible": true
              }
            ],
            "selection": {
              "mode": "multiple",
              "required_for_bulk_actions": true
            },
            "row_navigation": "/work-items/{name}",
            "row_actions": [
              "open",
              "update",
              "close",
              "delete"
            ],
            "bulk_actions": [
              "close",
              "delete"
            ]
          }
        }
      ]
    },
    {
      "route": "/work-items/:name",
      "title": "Work Item Detail",
      "layout": "detail_page",
      "navigation": {
        "group": "Work",
        "order": 2
      },
      "data_bindings": [
        {
          "name": "item",
          "query": {
            "transport": "graphql",
            "operation": "workItem",
            "variables": {
              "name": {
                "kind": "route",
                "path": "name"
              }
            },
            "result": {
              "path": "workItem"
            }
          }
        },
        {
          "name": "relatedItems",
          "query": {
            "transport": "graphql",
            "operation": "relatedWorkItems",
            "variables": {
              "name": {
                "kind": "route",
                "path": "name"
              }
            },
            "result": {
              "path": "relatedWorkItems.workItems"
            }
          }
        },
        {
          "name": "timeline",
          "query": {
            "transport": "graphql",
            "operation": "workItemTimeline",
            "variables": {
              "name": {
                "kind": "route",
                "path": "name"
              }
            },
            "result": {
              "path": "workItemTimeline.events"
            }
          }
        }
      ],
      "components": [
        {
          "id": "header",
          "kind": "detail_header",
          "data": {
            "binding": "item"
          },
          "detail": {
            "collection": "workItems",
            "title_field": "title",
            "subtitle_field": "owner",
            "status_field": "state",
            "actions": [
              "open",
              "update",
              "close",
              "delete"
            ],
            "sections": [
              {
                "id": "overview",
                "label": "Overview",
                "fields": [
                  "title",
                  "state",
                  "priority",
                  "owner",
                  "blocked"
                ]
              },
              {
                "id": "planning",
                "label": "Planning",
                "fields": [
                  "estimate_points",
                  "updated_at"
                ]
              }
            ],
            "tabs": [
              {
                "id": "summary",
                "label": "Summary",
                "sections": [
                  "overview",
                  "planning"
                ]
              },
              {
                "id": "related",
                "label": "Related",
                "related": [
                  "relatedItems"
                ]
              },
              {
                "id": "activity",
                "label": "Activity"
              }
            ],
            "related": [
              {
                "id": "relatedItems",
                "label": "Related Items",
                "collection": "workItems",
                "table": {
                  "collection": "workItems",
                  "columns": [
                    {
                      "id": "title",
                      "field": "title",
                      "label": "Title",
                      "sortable": false,
                      "visible": true
                    },
                    {
                      "id": "state",
                      "field": "state",
                      "label": "State",
                      "sortable": false,
                      "visible": true
                    },
                    {
                      "id": "updated",
                      "field": "updated_at",
                      "label": "Updated",
                      "sortable": true,
                      "visible": true
                    }
                  ],
                  "row_navigation": "/work-items/{name}",
                  "row_actions": [
                    "open"
                  ]
                },
                "data": {
                  "binding": "relatedItems"
                }
              }
            ],
            "timeline": {
              "title_field": "title",
              "time_field": "updated_at",
              "description_field": "state",
              "data": {
                "binding": "timeline"
              }
            }
          }
        },
        {
          "id": "payload",
          "kind": "table",
          "data": {
            "binding": "item",
            "path": "payload"
          },
          "table": {
            "collection": "workItems",
            "columns": [
              {
                "id": "payload",
                "field": "payload",
                "label": "Payload",
                "sortable": false,
                "visible": true
              }
            ]
          }
        }
      ]
    },
    {
      "route": "/work-items/dashboard",
      "title": "Work Item Dashboard",
      "layout": "dashboard",
      "navigation": {
        "group": "Work",
        "order": 3
      },
      "data_bindings": [
        {
          "name": "stats",
          "query": {
            "transport": "graphql",
            "operation": "workItemStats",
            "variables": {},
            "result": {
              "path": "workItemStats"
            }
          }
        },
        {
          "name": "series",
          "query": {
            "transport": "graphql",
            "operation": "workItemSeries",
            "variables": {},
            "result": {
              "path": "workItemSeries.points"
            }
          }
        }
      ],
      "components": [
        {
          "id": "kpis",
          "kind": "metric_row",
          "data": {
            "binding": "stats"
          },
          "metrics": [
            {
              "id": "open",
              "label": "Open",
              "value_path": "open_count",
              "format": "number"
            },
            {
              "id": "blocked",
              "label": "Blocked",
              "value_path": "blocked_count",
              "format": "number"
            },
            {
              "id": "done_rate",
              "label": "Done Rate",
              "value_path": "done_rate",
              "format": "percent"
            }
          ]
        },
        {
          "id": "throughput",
          "kind": "chart",
          "data": {
            "binding": "series"
          },
          "chart": {
            "kind": "bar",
            "title": "Throughput",
            "encoding": {
              "x": "day",
              "y": "completed_count",
              "color": "priority"
            },
            "height": 280,
            "stack": true
          }
        }
      ]
    }
  ]
}
